# ========== Backend Configuration ==========

# Server Port and Host
PORT=5000
HOST=0.0.0.0  # 0.0.0.0 for remote access, localhost for local only

# JWT Secret (change this in production!)
JWT_SECRET=coreinventory_secret_key_change_in_production

# ========== Email Configuration (for Password Reset OTP) ==========
# Leave empty to use demo mode (OTP will be shown in browser console and API response)

EMAIL_SERVICE=gmail  # Supported: gmail, outlook, yahoo
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Gmail Setup Guide:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://support.google.com/accounts/answer/185833
# 3. Create an "App Password" for Gmail
# 4. Use that password here (not your regular Gmail password)

# Alternative: Use any SMTP-compatible service
# EMAIL_SERVICE=smtp
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-password

# ========== Frontend Configuration ==========
# Set these in frontend/.env or frontend/.env.local

REACT_APP_API_URL=http://localhost:5000/api

# For Remote Deployment:
# Change REACT_APP_API_URL to: http://your-server-ip-or-domain:5000/api
# Then rebuild: npm run build:front
